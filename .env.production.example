POSTGRES_PASSWORD=replace-with-a-long-random-database-password
REQUIRE_POSTGRESQL=true
DATA_ENCRYPTION_KEY=generate-a-fernet-key
DATA_ENCRYPTION_KEY_VERSION=v1
DATA_ENCRYPTION_KEY_PREVIOUS=
MFA_ENCRYPTION_KEY=generate-a-separate-fernet-key
MFA_ENCRYPTION_KEY_PREVIOUS=
BACKUP_ENCRYPTION_KEY=generate-a-separate-fernet-key
BACKUP_DIR=/var/backups/bcb
BACKUP_RETENTION_COUNT=12
FORCE_HTTPS=true
ALLOWED_ORIGINS=https://payslips.example.bank
ALLOW_SELF_REGISTRATION=false
ENFORCE_MAKER_CHECKER=true
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_SECURITY=starttls
MAIL_USERNAME=finance@example.bank
MAIL_PASSWORD=replace-with-provider-secret
MAIL_DEFAULT_SENDER=finance@example.bank
DELIVERY_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
MALWARE_SCANNER_COMMAND=/usr/bin/clamscan
