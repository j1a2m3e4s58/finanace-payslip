# Use a persistent folder outside your replaceable code files in production/cPanel.
# Example: /home/yourcpaneluser/portal_data
PORTAL_DATA_DIR=/home/yourcpaneluser/portal_data
MAIL_SERVER=mail.bawjiasecommunitybank.com
MAIL_PORT=465
MAIL_SECURITY=ssl
MAIL_USERNAME=noreply@bawjiasecommunitybank.com
MAIL_PASSWORD=change-me
MAIL_DEFAULT_SENDER=noreply@bawjiasecommunitybank.com
# Optional: configure this when your provider can post Delivered/Bounced events.
DELIVERY_WEBHOOK_SECRET=replace-with-a-long-random-secret
# Generate independent Fernet keys with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=replace-with-a-fernet-key
BACKUP_ENCRYPTION_KEY=replace-with-a-different-fernet-key
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
ACCOUNT_LOCKOUT_MINUTES=15
FORCE_HTTPS=true
PORTAL_PUBLIC_URL=https://portal.bawjiasecommunitybank.com
ALLOWED_ORIGINS=http://127.0.0.1:4175,http://localhost:4175,https://portal.bawjiasecommunitybank.com
